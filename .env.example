# ============================================================
# URL Shortener Platform — Environment Configuration
# Copy this to .env and fill in values for local development.
# NEVER commit .env to source control.
# ============================================================

# --- Service Identity ---
SERVICE_NAME=url-shortener-api
SERVICE_VERSION=dev
ENVIRONMENT=development          # development | staging | production

# --- API Service ---
API_PORT=8080
API_READ_TIMEOUT_S=10
API_WRITE_TIMEOUT_S=30
API_IDLE_TIMEOUT_S=60
API_SHUTDOWN_TIMEOUT_S=30

# --- Redirect Service ---
REDIRECT_PORT=8081
REDIRECT_READ_TIMEOUT_S=5
REDIRECT_WRITE_TIMEOUT_S=10
REDIRECT_IDLE_TIMEOUT_S=60
REDIRECT_SHUTDOWN_TIMEOUT_S=30

# --- PostgreSQL ---
DB_PRIMARY_DSN=postgresql://urlshortener:secret@localhost:5432/urlshortener?sslmode=disable
DB_REPLICA_DSN=postgresql://urlshortener:secret@localhost:5432/urlshortener?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MIN_OPEN_CONNS=5
DB_CONN_MAX_LIFETIME_M=15
DB_CONN_MAX_IDLE_TIME_M=5

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=secret
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_DIAL_TIMEOUT_S=5
REDIS_READ_TIMEOUT_S=3
REDIS_WRITE_TIMEOUT_S=3

# --- Redis TTLs ---
REDIRECT_CACHE_TTL_S=3600        # 1 hour default
CACHE_NEGATIVE_TTL_S=60          # Cache "not found" for 60s to prevent DB hammering

# --- OpenTelemetry ---
OTEL_ENABLED=true
OTEL_EXPORTER=stdout             # stdout | otlp
OTEL_ENDPOINT=localhost:4317     # OTLP gRPC endpoint (used when OTEL_EXPORTER=otlp)
OTEL_SAMPLE_RATE=1.0             # 1.0 = 100% sampling (reduce in production)

# --- Logging ---
LOG_LEVEL=debug                  # debug | info | warn | error
LOG_FORMAT=json                  # json | text (use text for local readability)

# --- Short Codes ---
SHORT_CODE_LENGTH=7
BASE_URL=http://localhost:8081   # Public-facing redirect base URL

# --- JWT (Phase 1: local mock issuer) ---
JWT_ISSUER=http://localhost:9000
JWT_AUDIENCE=url-shortener-api
JWT_PUBLIC_KEY_PATH=./certs/jwt_public.pem

# --- PostgreSQL (Docker Compose vars) ---
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=secret
POSTGRES_DB=urlshortener
POSTGRES_PORT=5432

# --- Redis (Docker Compose vars) ---
REDIS_PORT=6379