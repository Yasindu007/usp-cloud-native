# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test artifacts
*.test
coverage.out
coverage.html

# Build cache
/tmp/

# Environment files — NEVER commit real secrets
.env
.env.local
.env.*.local
!.env.example

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Kubernetes generated files
kubeconfig
*.kubeconfig

# Terraform state — local only
deployments/terraform/.terraform/
deployments/terraform/*.tfstate
deployments/terraform/*.tfstate.backup
deployments/terraform/.terraform.lock.hcl

# Go
vendor/

# Certificates (never commit private keys)
*.pem
*.key
*.crt
*.p12
!certs/README.md

.gocache